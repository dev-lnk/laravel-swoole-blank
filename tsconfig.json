{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./public/js",
        "paths": {
            "@/*": ["./resources/ts/*"]
        },
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "resources/ts/**/*.ts"
    ],
    "exclude": ["node_modules"]
}