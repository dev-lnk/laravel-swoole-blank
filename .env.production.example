#======================================
# Docker Configuration
#======================================
IMAGE_TAG=latest
COMPOSE_PROJECT_NAME=laravel-swoole-blank

DOCKER_HUB_USER=your_dockerhub_username

APP_PATH=/var/www/app
APP_WEB_PORT=80
APP_POSTGRES_PORT=5432
APP_REDIS_PORT=6379
POSTGRES_PASSWORD=

GID=1000
UID=1000
#======================================
# Laravel Application Settings
#======================================
APP_NAME="laravel-swoole-blank"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Moscow
APP_URL=https://your-domain.com

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

#======================================
# Logging Configuration
#======================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

#======================================
# Database Configuration (PostgreSQL)
#======================================
DB_CONNECTION=pgsql
DB_HOST="${COMPOSE_PROJECT_NAME}-db"
DB_PORT=5432
DB_DATABASE="app-db"
DB_USERNAME=postgres
DB_PASSWORD="${POSTGRES_PASSWORD}"

#======================================
# Session Configuration
#======================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

#======================================
# Cache Configuration
#======================================
CACHE_STORE=redis
CACHE_PREFIX=laravel-swoole-blank_cache

#======================================
# Queue Configuration
#======================================
BROADCAST_CONNECTION=log
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=public

#======================================
# Redis Configuration
#======================================
REDIS_CLIENT=phpredis
REDIS_HOST="${COMPOSE_PROJECT_NAME}-redis"
REDIS_PASSWORD=null
REDIS_PORT=6379

#======================================
# Mail Configuration
#======================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

#======================================
# AWS Configuration (if needed)
#======================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

#======================================
# Vite Configuration
#======================================
VITE_APP_NAME="${APP_NAME}"

#======================================
# Laravel Octane Configuration
#======================================
OCTANE_SERVER=swoole
SWOOLE_LOG_LEVEL=2
SWOOLE_HTTP_COMPRESSION=true
SWOOLE_HTTP_COMPRESSION_LEVEL=6

#======================================
# Security Settings
#======================================
# Generate with: php artisan key:generate
# APP_KEY must be set before running the application

#======================================
# Additional Production Settings
#======================================
# Disable debug bar in production
DEBUGBAR_ENABLED=false

# Session security
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
